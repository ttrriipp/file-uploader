generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   @db.Text
  expiresAt DateTime
}

model Folder {
  id    Int    @id @default(autoincrement())
  name  String @unique
  files File[]
}

model File {
  id       Int    @id @default(autoincrement())
  url      String
  folder   Folder @relation(fields: [folderId], references: [id])
  folderId Int
}
