<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <h1><%= title %></h1>
    <form action="<%= folder.id %>/files/upload" method="get">
      <button type="submit">upload file</button>
    </form>
    <% if (locals.files) { %>
      <ul>
        <% files.forEach(file => { %>
          <li><a href="<%= folder.id %>/files/<%- file.id %>"><%= file.name %></a></li>
        <% }); %>
      </ul>
    <% } %>
    <a href="/">go back to home</a>
  </body>
</html>
